# DataSiteForge environment configuration.
# Copy to `.env` and adjust. All values are optional — sensible defaults apply.

# --- Execution mode -------------------------------------------------------
# "agent"      -> delegate cognitive tasks to an attached agent runtime
# "standalone" -> run without an agent runtime (forces mock fallback)
DSF_EXECUTION_MODE=standalone

# When false, the Agent Bridge always falls back to file-driven mocks.
DSF_IS_PRODUCTION=false

# --- Agent Bridge ---------------------------------------------------------
# Transport used to reach the orchestrating agent: "mcp", "stdio", or "mock".
DSF_AGENT_TRANSPORT=mock
# MCP / JSON-RPC endpoint (only used when transport=mcp).
# DSF_MCP_SERVER_URL=http://127.0.0.1:8787/rpc
DSF_AGENT_TIMEOUT_SECONDS=60

# --- Cloudflare (reserved for Phase 5) ------------------------------------
# DSF_CLOUDFLARE_API_TOKEN=
# DSF_CLOUDFLARE_ACCOUNT_ID=

# --- Control-plane API ----------------------------------------------------
# When set, `seo-platform serve` requires this token on all endpoints except the
# console (/) and health probe (/healthz), via Authorization: Bearer <token> or
# X-API-Key. Leave unset for open local development.
# DSF_API_TOKEN=

# --- Storage paths --------------------------------------------------------
# Defaults resolve under <repo>/data when unset.
# DSF_DATA_DIR=./data
# DSF_SQLITE_PATH=./data/state.sqlite
# DSF_DUCKDB_PATH=./data/analytics.duckdb
# DSF_MOCK_DIR=./data/mocks
