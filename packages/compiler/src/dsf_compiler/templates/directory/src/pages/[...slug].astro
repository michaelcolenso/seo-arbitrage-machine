---
// Fixed Invariant — programmatic per-route page (the long-tail SEO fleet).
// One statically-rendered page per high-volume column combination, sourced from
// src/data/routes.json. Content is server-rendered so it is indexable without JS.
import meta from '../data/meta.json';
import routes from '../data/routes.json';

export function getStaticPaths() {
  const all = (routes as { path: string }[]) ?? [];
  return all.map((route) => ({
    params: { slug: route.path.replace(/^\//, '') },
    props: { route },
  }));
}

interface Route {
  path: string;
  title: string;
  description: string;
  rows: Record<string, unknown>[];
}

const { route } = Astro.props as { route: Route };
const columns: string[] = Array.isArray(meta.columns) ? meta.columns : [];
const base: string = (meta as Record<string, string>).canonical_base ?? '';
const canonical = base ? base + route.path : '';
const rows = route.rows ?? [];
const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: route.title,
  description: route.description,
  numberOfItems: rows.length,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{route.title}</title>
    <meta name="description" content={route.description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <script type="application/ld+json" set:html={JSON.stringify(itemListLd)} />
  </head>
  <body class="bg-slate-50 text-slate-900 antialiased">
    <main class="mx-auto max-w-6xl px-4 py-10">
      <nav class="mb-6 text-sm">
        <a href="/" class="text-indigo-600 hover:underline">← All listings</a>
      </nav>
      <header class="mb-8">
        <h1 class="text-3xl font-bold tracking-tight">{route.title}</h1>
        <p class="mt-2 text-slate-600">{route.description}</p>
      </header>

      <div class="overflow-x-auto rounded-xl border border-slate-200 bg-white shadow-sm">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-100">
            <tr>
              {columns.map((col) => (
                <th class="px-4 py-3 text-left font-semibold text-slate-700">{col}</th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {rows.map((row) => (
              <tr class="hover:bg-slate-50">
                {columns.map((col) => (
                  <td class="px-4 py-3 text-slate-700">{String(row[col] ?? '')}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <footer class="mt-10 text-center text-xs text-slate-400">
        Generated by DataSiteForge · {meta.generated_at}
      </footer>
    </main>
  </body>
</html>
