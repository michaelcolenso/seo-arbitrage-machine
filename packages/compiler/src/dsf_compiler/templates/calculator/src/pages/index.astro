---
// Fixed Invariant — parametric analysis / ROI calculator.
// Consumes the strict JSON payload the compiler writes into src/data/meta.json.
import meta from '../data/meta.json';

const title: string = meta.title ?? 'Calculator';
const description: string = meta.description ?? '';
const calc = meta.calculator ?? { base: 0, result_label: 'Result', inputs: [] };
const inputs: { key: string; label: string; default: number; weight: number }[] =
  Array.isArray(calc.inputs) ? calc.inputs : [];
const base: string = (meta as Record<string, string>).canonical_base ?? '';
const appLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: title,
  description: description || title,
  applicationCategory: 'BusinessApplication',
  ...(base ? { url: base } : {}),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {base && <link rel="canonical" href={base + '/'} />}
    <script type="application/ld+json" set:html={JSON.stringify(appLd)} />
    <script defer src="https://unpkg.com/alpinejs@3.14.1/dist/cdn.min.js"></script>
  </head>
  <body class="bg-slate-50 text-slate-900 antialiased">
    <main class="mx-auto max-w-2xl px-4 py-12">
      <header class="mb-8">
        <h1 class="text-3xl font-bold tracking-tight">{title}</h1>
        {description && <p class="mt-2 text-slate-600">{description}</p>}
      </header>

      <div
        x-data="calculator()"
        x-init="init()"
        class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm"
      >
        <div class="grid gap-5">
          {inputs.map((input, idx) => (
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-slate-700">{input.label}</span>
              <input
                type="number"
                step="any"
                x-model.number={`values[inputs[${idx}].key]`}
                class="w-full rounded-lg border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
              />
            </label>
          ))}
        </div>

        <div class="mt-8 rounded-lg bg-indigo-600 p-6 text-center text-white">
          <div class="text-sm uppercase tracking-wide text-indigo-200" x-text="resultLabel"></div>
          <div class="mt-1 text-4xl font-bold" x-text="formatted()"></div>
        </div>
      </div>

      <footer class="mt-10 text-center text-xs text-slate-400">
        Generated by DataSiteForge · {meta.generated_at}
      </footer>
    </main>

    <script is:inline define:vars={{ calc }}>
      function calculator() {
        const inputs = Array.isArray(calc.inputs) ? calc.inputs : [];
        const values = {};
        for (const input of inputs) {
          values[input.key] = Number(input.default) || 0;
        }
        return {
          values,
          inputs,
          base: Number(calc.base) || 0,
          resultLabel: calc.result_label ?? 'Result',
          init() {},
          result() {
            let total = this.base;
            for (const input of this.inputs) {
              const v = Number(this.values[input.key]) || 0;
              total += v * (Number(input.weight) || 0);
            }
            return total;
          },
          formatted() {
            return this.result().toLocaleString(undefined, { maximumFractionDigits: 2 });
          },
        };
      }
      window.calculator = calculator;
    </script>
  </body>
</html>
