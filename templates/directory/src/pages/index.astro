---
// Fixed Invariant — searchable B2B data directory.
// Consumes the strict JSON payload the compiler writes into src/data/.
import rows from '../data/rows.json';
import meta from '../data/meta.json';

const columns: string[] =
  Array.isArray(meta.columns) && meta.columns.length > 0
    ? meta.columns
    : Object.keys((rows as Record<string, unknown>[])[0] ?? {});
const title: string = meta.title ?? 'Data Directory';
const description: string = meta.description ?? '';
const leadGen: boolean = Boolean(meta.lead_gen);
const leadWebhook: string = meta.lead_webhook ?? '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <script defer src="https://unpkg.com/alpinejs@3.14.1/dist/cdn.min.js"></script>
  </head>
  <body class="bg-slate-50 text-slate-900 antialiased">
    <main class="mx-auto max-w-6xl px-4 py-10">
      <header class="mb-8">
        <h1 class="text-3xl font-bold tracking-tight">{title}</h1>
        {description && <p class="mt-2 text-slate-600">{description}</p>}
      </header>

      <div x-data="directory()" x-init="init()">
        <div class="mb-4 flex items-center gap-3">
          <input
            type="search"
            x-model="q"
            placeholder="Search…"
            class="w-full max-w-sm rounded-lg border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
          />
          <span class="text-sm text-slate-500" x-text="`${filtered().length} results`"></span>
        </div>

        <div class="overflow-x-auto rounded-xl border border-slate-200 bg-white shadow-sm">
          <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="bg-slate-100">
              <tr>
                {columns.map((col, idx) => (
                  <th
                    scope="col"
                    class="cursor-pointer select-none px-4 py-3 text-left font-semibold text-slate-700 hover:bg-slate-200"
                    @click={`sortBy(columns[${idx}])`}
                  >
                    <span>{col}</span>
                    <span class="text-indigo-500" x-show={`sortKey === columns[${idx}]`} x-text="asc ? '▲' : '▼'"></span>
                  </th>
                ))}
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <template x-for="(row, i) in filtered()" :key="i">
                <tr class="hover:bg-slate-50">
                  {columns.map((col, idx) => (
                    <td class="px-4 py-3 text-slate-700" x-text={`row[columns[${idx}]]`}></td>
                  ))}
                </tr>
              </template>
            </tbody>
          </table>
        </div>

        {leadGen && (
          <section class="mt-10 rounded-xl border border-indigo-100 bg-indigo-50 p-6">
            <h2 class="text-xl font-semibold text-indigo-900">Get matched with a vendor</h2>
            <p class="mt-1 text-sm text-indigo-700">
              Tell us what you need and we'll connect you with vetted providers.
            </p>
            <form
              class="mt-4 grid gap-3 sm:grid-cols-3"
              method="post"
              action={leadWebhook || '#'}
              x-data="{ sent: false }"
              @submit={leadWebhook ? '' : 'sent = true; $event.preventDefault()'}
            >
              <input name="name" required placeholder="Name" class="rounded-lg border border-slate-300 px-3 py-2" />
              <input name="email" type="email" required placeholder="Work email" class="rounded-lg border border-slate-300 px-3 py-2" />
              <input name="company" placeholder="Company" class="rounded-lg border border-slate-300 px-3 py-2" />
              <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 font-medium text-white hover:bg-indigo-700 sm:col-span-3">
                Request quotes
              </button>
              <p x-show="sent" class="text-sm text-green-700 sm:col-span-3">Thanks — we'll be in touch.</p>
            </form>
          </section>
        )}
      </div>

      <footer class="mt-10 text-center text-xs text-slate-400">
        Generated by DataSiteForge · {meta.generated_at}
      </footer>
    </main>

    <script is:inline define:vars={{ rows, columns }}>
      function directory() {
        return {
          q: '',
          sortKey: columns[0] ?? '',
          asc: true,
          rows: rows,
          columns: columns,
          init() {},
          sortBy(key) {
            if (this.sortKey === key) {
              this.asc = !this.asc;
            } else {
              this.sortKey = key;
              this.asc = true;
            }
          },
          filtered() {
            const needle = this.q.trim().toLowerCase();
            let out = this.rows;
            if (needle) {
              out = out.filter((row) =>
                Object.values(row).some((v) => String(v).toLowerCase().includes(needle)),
              );
            }
            const key = this.sortKey;
            if (key) {
              out = [...out].sort((a, b) => {
                const av = a[key];
                const bv = b[key];
                const an = typeof av === 'number' ? av : String(av);
                const bn = typeof bv === 'number' ? bv : String(bv);
                if (an < bn) return this.asc ? -1 : 1;
                if (an > bn) return this.asc ? 1 : -1;
                return 0;
              });
            }
            return out;
          },
        };
      }
      window.directory = directory;
    </script>
  </body>
</html>
